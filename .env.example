# Application
APP_ENV=dev
# S7: when unset, HTTPS is enforced for APP_ENV=prod only. Set true/false to override.
# FORCE_HTTPS=false
BROKER_BASE_URL=http://localhost:8080
BROKER_NAME=GrandpaSSOn

# Session cookie (host-only AUTHSESSID)
SESSION_COOKIE_NAME=AUTHSESSID
# Forced true automatically when HTTPS enforcement is on (prod / FORCE_HTTPS=true).
SESSION_COOKIE_SECURE=false
SESSION_TTL_MINUTES=480
# Isolated reader cookie for gated publishing (R14); separate from AUTHSESSID
READER_SESSION_COOKIE_NAME=GPSREADER

# Database
# Host / CLI tools: 127.0.0.1 (MySQL port published by compose).
# docker-compose overrides DB_HOST=host.docker.internal for the web service.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=grandpasson
DB_USER=grandpasson
DB_PASSWORD=devpass

# Provisioning: comma-separated domains. Empty outside APP_ENV=dev refuses auto-create.
ALLOWED_EMAIL_DOMAINS=

# One-time / CLI migration protection (required if HTTP migrator is ever enabled)
MIGRATE_TOKEN=

# Minimal admin HTTP UI (/admin, /admin/api). Leave empty to keep admin HTTP disabled.
ADMIN_API_TOKEN=

# v1 machine-token defaults (client_credentials access tokens; see docs/grandpasson-spec-v1-extension.md)
# Default TTL 15 minutes; hard max 60 minutes. TTL is clamped to max when higher.
ACCESS_TOKEN_TTL_SECONDS=900
ACCESS_TOKEN_TTL_MAX_SECONDS=3600

# Days to retain enriched audit_log rows before cron pruning (v1 P0)
AUDIT_RETENTION_DAYS=90

# Rate limits (§11). Defaults match prior hardcoded values.
# DB-backed throttle for oauth token/introspect and other DB-limited endpoints (R13 / S9).
RATE_LIMIT_OAUTH_MAX=60
RATE_LIMIT_OAUTH_WINDOW_SECONDS=60
# Login / reader-login / callback throttle (S9): attempts per window, then lockout.
RATE_LIMIT_LOGIN_MAX=15
RATE_LIMIT_LOGIN_WINDOW_SECONDS=300
RATE_LIMIT_LOGIN_LOCKOUT_SECONDS=900

# Optional JWT companion for opaque access tokens (R15). Opaque remains revocable authority.
JWT_ACCESS_TOKEN_ENABLED=false
JWT_HMAC_SECRET=
# AES-256-GCM secret for RS256 private PEMs at rest (S2). Required when APP_ENV=prod before jwt:key-rotate.
JWT_KEY_ENCRYPTION_SECRET=

# Google OIDC
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/callback/google

# Microsoft OIDC (prefer single-tenant MS_TENANT_ID; use "common" only when intentional)
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=
MS_REDIRECT_URI=http://localhost:8080/callback/microsoft

# GitHub OAuth2
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8080/callback/github
